generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model alunos {
  id               Int                @id @default(autoincrement())
  user_id          Int                @unique
  data_nasc        DateTime?          @db.Date
  serie            String?            @db.VarChar(50)
  resp_tel         String?            @db.VarChar(20)
  resp_nome        String?            @db.VarChar(120)
  modalidade_id    Int
  tempo_aula       Int
  horas_semana     Decimal            @db.Decimal(5, 2)
  tempo_contrato   Int?
  status           String             @default("ATIVO") @db.VarChar(20)
  created_at       DateTime           @default(now()) @db.Timestamp(6)
  updated_at       DateTime           @default(now()) @db.Timestamp(6)
  modalidades      modalidades        @relation(fields: [modalidade_id], references: [id], map: "fk_alunos_modalidade")
  users            users              @relation(fields: [user_id], references: [id], map: "fk_alunos_user")
  frequencia_aluno frequencia_aluno[]
  turma_alunos     turma_alunos[]

  @@index([modalidade_id], map: "idx_alunos_modalidade_id")
  @@index([status], map: "idx_alunos_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model frequencia_aluno {
  id              Int          @id @default(autoincrement())
  turma_agenda_id Int
  aluno_id        Int
  status          String       @db.VarChar(30)
  confirmed_at    DateTime     @default(now()) @db.Timestamp(6)
  alunos          alunos       @relation(fields: [aluno_id], references: [id], map: "fk_frequencia_aluno_aluno")
  turma_agenda    turma_agenda @relation(fields: [turma_agenda_id], references: [id], map: "fk_frequencia_aluno_turma_agenda")

  @@index([aluno_id], map: "idx_frequencia_aluno_aluno_id")
  @@index([turma_agenda_id], map: "idx_frequencia_aluno_turma_agenda_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model frequencia_professor {
  id              Int          @id @default(autoincrement())
  turma_agenda_id Int
  professor_id    Int
  started_at      DateTime?    @db.Timestamp(6)
  ended_at        DateTime?    @db.Timestamp(6)
  notas           String?
  professores     professores  @relation(fields: [professor_id], references: [id], map: "fk_frequencia_professor_professor")
  turma_agenda    turma_agenda @relation(fields: [turma_agenda_id], references: [id], map: "fk_frequencia_professor_turma_agenda")

  @@index([professor_id], map: "idx_frequencia_professor_professor_id")
  @@index([turma_agenda_id], map: "idx_frequencia_professor_turma_agenda_id")
}

model modalidades {
  id          Int           @id @default(autoincrement())
  tipo        String        @unique @db.VarChar(100)
  alunos      alunos[]
  professores professores[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model professores {
  id                   Int                    @id @default(autoincrement())
  user_id              Int                    @unique
  materia              String                 @db.VarChar(100)
  modalidade_id        Int
  status               String                 @default("ATIVO") @db.VarChar(20)
  created_at           DateTime               @default(now()) @db.Timestamp(6)
  updated_at           DateTime               @default(now()) @db.Timestamp(6)
  frequencia_professor frequencia_professor[]
  modalidades          modalidades            @relation(fields: [modalidade_id], references: [id], map: "fk_professores_modalidade")
  users                users                  @relation(fields: [user_id], references: [id], map: "fk_professores_user")
  turma_professores    turma_professores[]

  @@index([modalidade_id], map: "idx_professores_modalidade_id")
  @@index([status], map: "idx_professores_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model turma_agenda {
  id                   Int                    @id @default(autoincrement())
  turma_id             Int
  dia_semana           Int                    @db.SmallInt
  horario_inicio       DateTime               @db.Time(6)
  horario_fim          DateTime               @db.Time(6)
  created_at           DateTime               @default(now()) @db.Timestamp(6)
  updated_at           DateTime               @default(now()) @db.Timestamp(6)
  frequencia_aluno     frequencia_aluno[]
  frequencia_professor frequencia_professor[]
  turmas               turmas                 @relation(fields: [turma_id], references: [id], onDelete: Cascade, map: "fk_turma_agenda_turma")

  @@unique([turma_id, dia_semana, horario_inicio, horario_fim], map: "uq_turma_agenda_slot")
  @@index([dia_semana], map: "idx_turma_agenda_dia_semana")
  @@index([turma_id], map: "idx_turma_agenda_turma_id")
}

model turma_alunos {
  id         Int      @id @default(autoincrement())
  turma_id   Int
  alunos_id  Int
  created_at DateTime @default(now()) @db.Timestamp(6)
  alunos     alunos   @relation(fields: [alunos_id], references: [id], map: "fk_turma_alunos_aluno")
  turmas     turmas   @relation(fields: [turma_id], references: [id], onDelete: Cascade, map: "fk_turma_alunos_turma")

  @@index([alunos_id], map: "idx_turma_alunos_alunos_id")
}

model turma_professores {
  id             Int         @id @default(autoincrement())
  turma_id       Int
  professores_id Int
  created_at     DateTime    @default(now()) @db.Timestamp(6)
  turmas         turmas      @relation(fields: [turma_id], references: [id], onDelete: Cascade, map: "fk_turma_professores_turma")
  professores    professores @relation(fields: [professores_id], references: [id], map: "fk_turma_professsores_professor")

  @@unique([turma_id, professores_id], map: "uq_turma_professores")
  @@index([professores_id], map: "idx_turma_professores_professores_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model turmas {
  id                Int                 @id @default(autoincrement())
  nome              String              @unique @db.VarChar(50)
  horas_semana      Decimal             @db.Decimal(5, 2)
  status            String              @default("ATIVO") @db.VarChar(20)
  created_at        DateTime            @default(now()) @db.Timestamp(6)
  updated_at        DateTime            @default(now()) @db.Timestamp(6)
  turma_agenda      turma_agenda[]
  turma_alunos      turma_alunos[]
  turma_professores turma_professores[]

  @@index([status], map: "idx_turmas_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id          Int          @id @default(autoincrement())
  nome        String       @db.VarChar(120)
  email       String       @unique @db.VarChar(180)
  senha_hash  String       @db.VarChar(255)
  role        String       @db.VarChar(20)
  tel         String?      @db.VarChar(20)
  status      String       @default("ATIVO") @db.VarChar(20)
  created_at  DateTime     @default(now()) @db.Timestamp(6)
  updated_at  DateTime     @default(now()) @db.Timestamp(6)
  alunos      alunos?
  professores professores?

  @@index([role], map: "idx_users_role")
  @@index([status], map: "idx_users_status")
}
